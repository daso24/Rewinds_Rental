# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
!lib/*.jar   # AÑADIDO: Esta es una excepción. Le dice a Git "Ignora todos los .jar, EXCEPTO los que estén en la carpeta lib"
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Archivos específicos de Eclipse
.settings/
#.classpath  # APAGADO: Le pusimos un # para que Git sí suba tu mapa de carpetas
#.project    # APAGADO: Le pusimos un # para que Git sí suba la configuración

# Carpetas de compilación
bin/

# Credenciales
#config.properties # APAGADO: Le pusimos un # para que sí suba la contraseña a la laptop

# Ignorar PDFs generados por el sistema
src/main/java/pdfs/
*.pdf